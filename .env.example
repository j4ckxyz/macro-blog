# Macroblog — the ONE file you configure for Docker.
# Copy to .env, edit, then:  docker compose up -d --build

# Public URL of your blog (use your real https domain in production).
# Domain migration: change this value (and point your new domain's DNS at the
# server), then restart — MACROBLOG_SITE_URL always wins over the saved config.
# Post permalinks are date+slug based, so every post keeps the same path under
# the new domain (e.g. /2026/06/15/my-post/). Only the host changes.
MACROBLOG_SITE_URL=http://127.0.0.1:3000

# Identity
MACROBLOG_SITE_TITLE=My Blog
MACROBLOG_AUTHOR=Your Name
MACROBLOG_USERNAME=yourhandle
MACROBLOG_DESCRIPTION=Short bio

# Admin password — set on first boot. Change it, keep it secret.
MACROBLOG_ADMIN_PASSWORD=change-me-please

# Host port to publish (container always listens on 3000 internally).
MACROBLOG_PORT=3000
