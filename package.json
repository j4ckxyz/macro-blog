{
  "name": "macroblog",
  "version": "0.1.0",
  "description": "Self-hosted, single-user, Micro.blog-compatible microblogging platform",
  "type": "module",
  "module": "src/server.ts",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "db:migrate": "bun run src/db/index.ts --migrate",
    "macroblog": "bun run src/cli.ts"
  },
  "bin": {
    "macroblog": "src/cli.ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "js-yaml": "^4.1.0",
    "microformats-parser": "^1.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9"
  }
}
