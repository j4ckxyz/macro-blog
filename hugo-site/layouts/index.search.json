{{- /* Client-side fuzzy search index — every post, plain text, trimmed. */ -}}
{{- $reply := .Site.Params.include_reply_type -}}
{{- $pages := where .Site.RegularPages "Section" "in" (slice "posts" "articles" "photos" "bookmarks" "podcasts") -}}
{{- if $reply }}{{ $pages = .Site.RegularPages }}{{ end -}}
{{- $arr := slice -}}
{{- range $pages -}}
  {{- $item := dict
    "url" .RelPermalink
    "title" (.Title | default "")
    "text" (.Plain | htmlUnescape | chomp | truncate 280 "")
    "date" (.Date.Format "2006-01-02")
    "section" .Section
  -}}
  {{- with .Params.categories }}{{ $item = merge $item (dict "tags" .) }}{{ end -}}
  {{- $arr = $arr | append $item -}}
{{- end -}}
{{- $arr | jsonify -}}
