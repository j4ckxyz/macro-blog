site:
  url: "https://yoursite.com"          # Must be HTTPS in prod, http://127.0.0.1:3000 for dev
  title: "Your Blog Name"
  author: "Your Name"
  username: "yourhandle"               # Used in rel-me links and webfinger
  description: "Short bio"
  avatar: "/uploads/avatar.jpg"
  language: "en"
  timezone: "Europe/London"

server:
  port: 3000
  host: "127.0.0.1"                    # Behind a reverse proxy in prod

hugo:
  binary: "hugo"                       # Path to hugo binary
  theme: ""                            # Leave blank for default, or name of theme in hugo-site/themes/
  version: "0.147.0"

auth:
  # IndieAuth password hash (bcrypt/argon2). Set with: bun run macroblog --set-password
  password_hash: ""
  session_secret: ""                   # 64-char random string; set with: bun run macroblog --gen-secret

crossposting:
  bluesky:
    enabled: false
    handle: ""                         # e.g. you.bsky.social or your.domain
    pds_url: "https://bsky.social"     # Your PDS URL
    # OAuth tokens stored in DB — do not put them here

  mastodon:
    enabled: false
    instance_url: ""                   # e.g. https://mastodon.social or https://gotosocial.yourserver.com
    # OAuth tokens stored in DB — do not put them here

webmentions:
  send: true
  receive: true
  moderation: true                     # Hold webmentions for approval

feeds:
  posts_per_page: 20
  include_reply_type: false            # Whether replies appear in main feed

media:
  max_file_size: 52428800              # 50MB

microblog:
  # Optional: ping Micro.blog when you publish (for feed-based syndication)
  ping_enabled: false
  ping_url: "https://micro.blog/ping"

appearance:
  # All editable from the admin (Settings → Appearance).
  font: "system"                       # system | sans | serif | mono | rounded
  accent_color: "#111111"
  background_color: "#ffffff"
  text_color: "#222426"
